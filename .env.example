# Ejemplo de configuración para Railway PostgreSQL
# Copia este archivo como .env y reemplaza con tus valores reales

# URL de conexión de PostgreSQL desde Railway
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:password@containers-us-west-123.railway.app:5432/railway

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=8081
